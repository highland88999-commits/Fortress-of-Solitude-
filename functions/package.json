{
  "name": "olympus-vault-signer",
  "version": "1.0.0",
  "description": "Olympus LLC Secure Serverless Token Signing Engine for Private Shard Storage",
  "main": "index.js",
  "scripts": {
    "preserve": "npm run build",
    "build": "echo 'Compiling Olympus Matrix Engine...'",
    "install:all": "npm install",
    "deploy": "firebase deploy --only functions --token \"$FIREBASE_TOKEN\""
  },
  "engines": {
    "node": "18"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/s3-request-presigner": "^3.500.0",
    "firebase-admin": "^11.8.0",
    "firebase-functions": "^4.3.1"
  },
  "devDependencies": {
    "firebase-tools": "^13.0.0"
  },
  "private": true
}
